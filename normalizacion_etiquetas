df = pd.read_csv(r"C:\Users\pc\Desktop\Aime\Documents\Licenciatura en Ciencias de Datos\Práctica profesional\etiquetas.csv")

# pasar a minúsculas
df = df.apply(lambda col: col.str.lower() if col.dtype == "object" else col)

# quitar tildes
def quitar_tildes(texto):
    if isinstance(texto, str):
        return "".join(
            c for c in unicodedata.normalize("NFD", texto)
            if unicodedata.category(c) != "Mn"
        )
    return texto

df = df.apply(lambda col: col.map(quitar_tildes) if col.dtype == "object" else col)
df = df.apply(lambda col: col.str.strip() if col.dtype == "object" else col)
df["Tema"] = df["Tema"].fillna("sin_tema")
df["Tema"] = df["Tema"].replace("", "sin_tema")
df["Tema"] = df["Tema"].astype(str).apply(lambda x: re.sub(r"[^\w\s]", "", x))
df["Subtema"] = df["Subtema"].astype(str).apply(lambda x: re.sub(r"[^\w\s]", "", x))
df["Subtema 2"] = df["Subtema 2"].astype(str).apply(lambda x: re.sub(r"[^\w\s]", "", x))
df_ordenado = df.sort_values(by="Tema", key=lambda x: x.str.strip())

df_ordenado.to_excel("etiquetas_ordenadas.xlsx", index=False)
df_ordenado.to_csv("etiquetas_ordenadas.csv", index=False)
